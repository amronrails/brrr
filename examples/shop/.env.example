APP_ENV=development
HTTP_PORT=8080

# Postgres connection used by the server, goose and sqlc.
DATABASE_URL=postgres://shop:shop_dev@localhost:5432/shop?sslmode=disable

# Auth — CHANGE JWT_SECRET before deploying (use 32+ random bytes).
JWT_SECRET=dev-secret-change-me-please-32bytes-min
JWT_ISSUER=shop
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Comma-separated list of allowed CORS origins (the Vite dev server by default).
CORS_ORIGINS=http://localhost:5173
