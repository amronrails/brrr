services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{.DBName}}
      POSTGRES_USER: {{.DBUser}}
      POSTGRES_PASSWORD: {{.DBPassword}}
    ports:
      - "{{.DBPort}}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{.DBUser}} -d {{.DBName}}"]
      interval: 5s
      timeout: 5s
      retries: 10

volumes:
  pgdata:
