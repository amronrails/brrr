// Package modules wires together the application's feature modules. Each module
// owns a vertical slice (domain → repository → service → transport) and exposes
// itself through the Module interface so the server can mount it.
package modules

import (
	"github.com/go-chi/chi/v5"
	"github.com/go-playground/validator/v10"
	"github.com/jackc/pgx/v5/pgxpool"

	"{{.ModulePath}}/internal/db"
	"{{.ModulePath}}/internal/modules/user"
	// brrr:module-imports
	"{{.ModulePath}}/internal/platform/auth"
	"{{.ModulePath}}/internal/platform/config"
)

// Module is the contract every feature module satisfies.
type Module interface {
	Name() string
	RegisterRoutes(r chi.Router)
}

// Deps are the shared dependencies handed to every module at construction.
type Deps struct {
	Pool      *pgxpool.Pool
	Queries   *db.Queries
	Tokens    *auth.TokenService
	Validator *validator.Validate
	Config    *config.Config
}

// New constructs every module in the application. New modules generated by
// `brrr generate` are appended at the marker below.
func New(d Deps) []Module {
	return []Module{
		user.New(user.Deps{Queries: d.Queries, Tokens: d.Tokens, Validator: d.Validator}),
		// brrr:modules
	}
}
