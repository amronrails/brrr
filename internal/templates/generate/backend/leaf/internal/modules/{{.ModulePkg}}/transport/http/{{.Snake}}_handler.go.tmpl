func (h *{{.Pascal}}Handler) create(w http.ResponseWriter, r *http.Request) {
	var req {{.Camel}}Request
	if err := httpx.Decode(r, &req); err != nil {
		httpx.Error(w, http.StatusBadRequest, "invalid request body")
		return
	}
	if err := h.validate.Struct(req); err != nil {
		httpx.ValidationError(w, err)
		return
	}
	m, err := h.svc.Create(r.Context(), domain.Create{{.Pascal}}Input{
{{- range .Columns }}
		{{.GoName}}: req.{{.GoName}},
{{- end }}
	})
	if err != nil {
		write{{.Pascal}}Error(w, err)
		return
	}
	httpx.JSON(w, http.StatusCreated, to{{.Pascal}}Response(m))
}

func (h *{{.Pascal}}Handler) list(w http.ResponseWriter, r *http.Request) {
	limit := httpx.QueryInt(r, "limit", 20)
	offset := httpx.QueryInt(r, "offset", 0)
	items, total, err := h.svc.List(r.Context(), int32(limit), int32(offset))
	if err != nil {
		write{{.Pascal}}Error(w, err)
		return
	}
	out := make([]{{.Camel}}Response, 0, len(items))
	for _, m := range items {
		out = append(out, to{{.Pascal}}Response(m))
	}
	httpx.JSON(w, http.StatusOK, map[string]any{
		"data":   out,
		"total":  total,
		"limit":  limit,
		"offset": offset,
	})
}

func (h *{{.Pascal}}Handler) get(w http.ResponseWriter, r *http.Request) {
