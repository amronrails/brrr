// New{{.Pascal}}Handler constructs a {{.Pascal}}Handler.
func New{{.Pascal}}Handler(svc *service.{{.Pascal}}Service, validate *validator.Validate) *{{.Pascal}}Handler {
	return &{{.Pascal}}Handler{svc: svc, validate: validate}
