	w.WriteHeader(http.StatusNoContent)
}

// RegisterRoutes mounts the {{.Snake}} CRUD endpoints (all require auth).
func (h *{{.Pascal}}Handler) RegisterRoutes(r chi.Router, tokens *auth.TokenService) {
	r.Group(func(r chi.Router) {
		r.Use(tokens.RequireAuth)
		r.Post("/{{.RoutePrefix}}", h.create)
		r.Get("/{{.RoutePrefix}}", h.list)
		r.Get("/{{.RoutePrefix}}/{id}", h.get)
		r.Put("/{{.RoutePrefix}}/{id}", h.update)
		r.Delete("/{{.RoutePrefix}}/{id}", h.delete)
	})
}

func write{{.Pascal}}Error(w http.ResponseWriter, err error) {
	switch {
	case errors.Is(err, domain.Err{{.Pascal}}NotFound):
		httpx.Error(w, http.StatusNotFound, err.Error())
	default:
		httpx.Error(w, http.StatusInternalServerError, "internal server error")
	}
}
